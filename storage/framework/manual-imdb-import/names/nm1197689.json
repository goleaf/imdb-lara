    "trivia": {
        "triviaEntries": [
            {
                "id": "nt0157878",
                "text": "She studied at the Ernst Busch Acting Academy in Berlin from 1996 to 2000.",
                "interestCount": 17,
                "voteCount": 19
            },
            {
                "id": "nt0157879",
                "text": "She acted at the Theaterhaus Jena from 1999 to 2001. After that she acted at the Schauspiel Leipzig from 2001 to 2002. She then accepted an invitation to join the Theater Basel where she acted from 2002 to 2006.",
                "interestCount": 9,
                "voteCount": 10
            },
            {
                "id": "nt0157880",
                "text": "She was named Best Newcomer Actress by the Theater Heute in 2003 for her performances in \"Romeo und Julia\" and \"Die sexuellen Neurosen unserer Eltern\" at the Theater Basel.",
                "interestCount": 19,
                "voteCount": 19
            },
            {
                "id": "nt1456138",
                "text": "For her performance in Requiem (2006), she was one of three consecutive German winners of the Silver Bear for Best Actress at Berlin Film Festival: she was preceded by Julia Jentsch in Sophie Scholl: The Final Days (2005) and followed by Nina Hoss in Yella (2007).",
                "interestCount": 19,
                "voteCount": 21
            },
            {
                "id": "nt2211487",
                "text": "She has starred in German, Austrian, British, and French films.",
                "interestCount": 22,
                "voteCount": 24
            },
            {
                "id": "nt2211488",
                "text": "Hüller speaks German, French, and English.",
                "interestCount": 39,
                "voteCount": 39
            },
            {
                "id": "nt2330104",
                "text": "She has a daughter, Ruby (b.2011).",
                "interestCount": 16,
                "voteCount": 17
            },
            {
                "id": "nt2379141",
                "text": "She starred in two films that were nominated for Best Picture at the 2024 Academy Awards, The Zone of Interest (2023) and Anatomy of a Fall (2023).",
                "interestCount": 19,
                "voteCount": 20
            },
            {
                "id": "nt2406975",
                "text": "Was invited to join the Actors branch of the Academy of Motion Picture Arts & Sciences (AMPAS) in 2024.",
                "interestCount": 3,
                "voteCount": 5
            }
        ],
        "totalCount": 9
    },
