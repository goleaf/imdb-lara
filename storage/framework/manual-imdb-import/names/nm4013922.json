    "trivia": {
        "triviaEntries": [
            {
                "id": "nt1463617",
                "text": "Is the co-artistic director of the NYC Theatre company Strangemen and Co. and co-founded it in 2011 with actor, Jason Ralph.",
                "interestCount": 3,
                "voteCount": 3
            },
            {
                "id": "nt1463618",
                "text": "Was awarded an OBIE in 2016 for the puppet design in his show, The Woodsman.",
                "interestCount": 3,
                "voteCount": 3
            },
            {
                "id": "nt1463619",
                "text": "Graduate from the SUNY Purchase Conservatory of Acting.",
                "interestCount": 5,
                "voteCount": 5
            },
            {
                "id": "nt2490373",
                "text": "Is a performer that also designs and directs puppetry for theatre and opera.",
                "interestCount": 15,
                "voteCount": 15
            },
            {
                "id": "nt2490376",
                "text": "Played and voiced the character of Rocky for Project Hail Mary (2026) and led his team of 4-7 additional puppeteers to bring the character to life on set.",
                "interestCount": 23,
                "voteCount": 23
            },
            {
                "id": "nt2490377",
                "text": "Has coincidentally played two puppet characters named Rocky.",
                "interestCount": 8,
                "voteCount": 10
            },
            {
                "id": "nt2490378",
                "text": "From Richardson, Texas.",
                "interestCount": 9,
                "voteCount": 10
            },
            {
                "id": "nt2490379",
                "text": "Designed the puppets for the 2022 Broadway revival of Into the Woods, including Milky White, who became a viral sensation as well as the subject of several articles and fan tattoos.",
                "interestCount": 7,
                "voteCount": 8
            },
            {
                "id": "nt2490380",
                "text": "Directed, designed, wrote and performed in 2016's The Woodsman.",
                "interestCount": 7,
                "voteCount": 7
            }
        ],
        "totalCount": 9
    },
